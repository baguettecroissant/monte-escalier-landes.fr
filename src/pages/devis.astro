---
import Layout from '../layouts/Layout.astro';
import StepsForm from '../components/StepsForm.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Demande de Devis Monte-Escalier Gratuit — Landes (40) | Installation & Aides";
const description = "Estimez rapidement le prix de votre monte-escalier droit, tournant ou extérieur dans les Landes. Obtenez 3 devis comparatifs gratuits d'installateurs locaux.";

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Demande de Devis Monte-Escalier" }
];
---

<Layout title={title} description={description}>
  <Breadcrumb items={breadcrumbItems} />

  <section style="padding: 50px 0 80px; background: linear-gradient(135deg, rgba(22,101,52,0.04) 0%, rgba(192,38,211,0.02) 100%);">
    <div class="container" style="max-width: 800px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">⏱️ Simulation en 2 minutes</span>
        <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Votre Devis Monte-Escalier dans les Landes
        </h1>
        <p style="font-size: 18px; color: var(--text-muted); line-height: 1.6;">
          Remplissez notre formulaire intelligent pour estimer le budget de votre projet d'accessibilité. Nous transmettons votre demande uniquement à des installateurs agréés du 40 proches de chez vous.
        </p>
      </div>

      <div>
        <StepsForm />
      </div>

      <div class="grid-3" style="margin-top: 60px; text-align: center; gap: 20px;">
        <div style="background: white; border: 2px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
          <div style="font-size: 32px; margin-bottom: 10px;">📋</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">1. Décrivez votre projet</h3>
          <p style="font-size: 15px; color: var(--text-muted); line-height: 1.5; margin: 0;">Indiquez la forme de votre escalier, le matériau des marches, et le degré d'urgence de l'installation.</p>
        </div>
        
        <div style="background: white; border: 2px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
          <div style="font-size: 32px; margin-bottom: 10px;">📞</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">2. Étude Téléphonique</h3>
          <p style="font-size: 15px; color: var(--text-muted); line-height: 1.5; margin: 0;">Un conseiller local valide vos choix par téléphone pour estimer votre reste à charge réel après subventions (CD 40 / Anah).</p>
        </div>

        <div style="background: white; border: 2px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
          <div style="font-size: 32px; margin-bottom: 10px;">🤝</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">3. Comparez &amp; Choisissez</h3>
          <p style="font-size: 15px; color: var(--text-muted); line-height: 1.5; margin: 0;">Recevez gratuitement et sans engagement jusqu'à 3 offres sur mesure d'artisans basés dans les Landes.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
